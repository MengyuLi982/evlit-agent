# LLM provider (LiteLLM-compatible)
# Preferred for OpenAI-compatible gateways
EVAGENT_API_KEY=
EVAGENT_API_BASE=
EVAGENT_CHAT_MODEL=qwen3-max
EVAGENT_EMBED_MODEL=text-embedding-v3

# Legacy DashScope variables (still supported as fallback)
DASHSCOPE_API_KEY=
DASHSCOPE_API_BASE=

# Search API keys (optional but recommended)
S2_API_KEY=
OPENALEX_API_KEY=
CROSSREF_MAILTO=

# Infra
QDRANT_URL=http://localhost:6333
GROBID_URL=http://localhost:8070

# Runtime
EVAGENT_RUNS_DIR=runs
EVAGENT_CACHE_DIR=.cache/evagent
EVAGENT_LOG_LEVEL=INFO
